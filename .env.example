# Gemini API 키
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# 발송자 Gmail 주소
EMAIL_SENDER=your_email@gmail.com

# 수신자 이메일 (쉼표로 복수 지정 가능: a@gmail.com,b@gmail.com)
EMAIL_RECEIVER=receiver@gmail.com

# Gmail 앱 비밀번호 (Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호)
# 일반 Gmail 비밀번호가 아닌 16자리 앱 전용 비밀번호를 입력하세요
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
